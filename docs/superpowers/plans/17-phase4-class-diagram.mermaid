classDiagram
    class DiagnosisContext {
        +currentConnection: Object
        +activeExecutions: Map
        +listeners: Set
        +onConnectionChange(conn: Object) void
        +registerExecution(id: string, capId: number, name: string) void
        +completeExecution(id: string, status: string, result: Object) void
        +pollExecution(runId: string, interval: number) Promise
        +cancelExecution(id: string) void
        +addEventListener(type: string, callback: Function) Function
        -_notifyListeners(type: string, data: Object) void
    }

    class ConnectionStore {
        -_state: Object
        -_listeners: Array
        +getState() Object
        +setState(updates: Object) void
        +subscribe(fn: Function) Function
        +getCurrentConnId() string
        +getCurrentConnection() Object
        +setConnectionState(state: string) void
        +init() void
        -_persist() void
        -syncToGlobal() void
    }

    class DiagnosisPageState {
        +currentFilter: Object
        +selectedCapability: Object
        +executionHistory: Array
        +setFilter(filter: Object) void
        +selectCapability(cap: Object) void
        +refreshHistory() void
    }

    class CapabilityPanel {
        +loadCapabilities() Promise
        +renderCapabilityCards() void
        +setupFilterHandlers() void
        -groupByLevel(caps: Array) Object
        -renderCapabilityCard(cap: Object) string
        -filterCapabilitiesByConnection(caps: Array, level: string) Array
    }

    class ParameterForm {
        +showParameterForm(capId: number) Promise
        +renderForm(cap: Object) void
        +submitForm(event: Event, capId: number) Promise
        -parseSchema(schemaStr: string) Array
        -renderFormField(field: Object) string
        -validateForm(params: Object, cap: Object) string
    }

    class ExecutionTracker {
        +registerDiagnosisExecution(id: string, name: string, startTime: number) void
        +completeDiagnosisExecution(id: string, status: string) void
        +getDiagnosisActiveCount() number
        -updateExecutionIndicator() void
        -getExecutionList() Array
    }

    class ProgressDisplay {
        +showProgress(name: string, steps: Array) void
        +updateStepStatus(stepOrder: number, status: string, output: string) void
        +closeProgress() void
        -renderProgress() void
        -getStatusIcon(status: string) string
    }

    class ResultDisplay {
        +renderResult(result: Object, capability: Object) void
        -renderSingleResult(result: Object, capability: Object, container: Element) void
        -renderScenarioResult(result: Object, capability: Object, container: Element) void
        -formatOutput(body: any) string
        -getStatusText(status: string) string
    }

    class ResultRenderer {
        +renderDiagnosisResult(result: Object, capability: Object) string
        -detectRenderMode(result: Object, capability: Object) string
        -renderTraceTable(data: Array) string
        -renderFileLinks(data: Object) string
        -renderMarkdown(text: string) string
        -renderMultiStep(steps: Array) string
        -renderText(text: string) string
    }

    class HistoryPanel {
        +diagHistoryInit() Promise
        +loadHistory(filters: Object) Promise
        +renderHistory() void
        +viewHistoryDetail(runId: string) Promise
        -parseJson(value: any, fallback: any) any
        -getStatusText(status: string) string
    }

    ConnectionStore <|-- DiagnosisContext
    DiagnosisContext <|-- DiagnosisPageState
    DiagnosisPageState <|-- CapabilityPanel
    DiagnosisPageState <|-- ParameterForm
    DiagnosisPageState <|-- ExecutionTracker
    DiagnosisPageState <|-- ProgressDisplay
    DiagnosisPageState <|-- ResultDisplay
    ResultDisplay <|-- ResultRenderer
    DiagnosisPageState <|-- HistoryPanel
