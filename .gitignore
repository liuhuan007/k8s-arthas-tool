# K8s Arthas Tool - .gitignore

# 隐藏文件/目录（以 . 开头），保留 .gitignore 本身
.*
!.gitignore
.agent/
.agents/
.workbuddy/
.specify/
.venv/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# 数据库（运行时文件，不提交）
config/db/*.db

# 配置文件 (集群配置可能包含敏感信息)
config/data/clusters.json

# 日志
*.log
logs/

# 输出文件
data/profiler/
data/hotfix/
data/task_runs/
data/tool_packages/
data/db/arthas.db
*.hprof

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 临时文件
*.tmp
*.bak
*.db-shm
*.db-wal
__part*.py
__transform.py

# 临时提交文件
code-commit.md
