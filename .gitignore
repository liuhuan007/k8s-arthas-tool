# K8s Arthas Tool - .gitignore

# 隐藏文件/目录（以 . 开头），保留 .gitignore 本身
.*
!.gitignore
.agent/
.agents/
.workbuddy/
.specify/
.venv/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# 数据库 (不包含敏感数据,可以提交)
# config/db/*.db

# 配置文件 (集群配置可能包含敏感信息)
config/data/clusters.json
config/data/db/*.db

# 日志
*.log
logs/

# 输出文件
profiler_output/
*.hprof
*.html
*.txt

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 临时文件
*.tmp
*.bak
*.db-shm
*.db-wal
__part*.py
__transform.py
# Added by code-review-graph
.code-review-graph/



